# Copy these values into the second PC's local launcher environment.
# Do not commit real secrets or machine-specific tokens.

JARVIS_NODE_ROLE=worker
JARVIS_NODE_ID=worker-3090
JARVIS_WORKER_MODEL=qwen3.6-35b-a3b-rotorquant
JARVIS_WORKER_REPO=Jameschat/OpenJarvis3090

# Worker exposes LiteLLM to the main PC.
JARVIS_WORKER_LITELLM_URL=http://127.0.0.1:4000/v1/chat/completions
